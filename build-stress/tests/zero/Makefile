	cd /home/wangmaosen/app/cpp/KVStore/build-stress && $(MAKE) $(MAKESILENT) -f tests/zero/CMakeFiles/test_zero_init.dir/build.make tests/zero/CMakeFiles/test_zero_init.dir/test_zero_init.cpp.i
.PHONY : test_zero_init.cpp.i

test_zero_init.s: test_zero_init.cpp.s
.PHONY : test_zero_init.s

# target to generate assembly for a file
test_zero_init.cpp.s:
	cd /home/wangmaosen/app/cpp/KVStore/build-stress && $(MAKE) $(MAKESILENT) -f tests/zero/CMakeFiles/test_zero_init.dir/build.make tests/zero/CMakeFiles/test_zero_init.dir/test_zero_init.cpp.s
.PHONY : test_zero_init.cpp.s

